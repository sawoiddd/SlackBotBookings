# ── Slack credentials (required) ──────────────────────────────────────────
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...

# ── Yarooms auth — Option A: static API key ──────────────────────────────
YAROOMS_API_KEY=your-yarooms-bearer-token

# ── Yarooms auth — Option B: email / password (used when no API key) ─────
# YAROOMS_EMAIL=you@example.com
# YAROOMS_PASSWORD=secret
# YAROOMS_SUBDOMAIN=KSE

# ── Yarooms base URL (defaults to https://api.yarooms.com) ──────────────
YAROOMS_BASE_URL=https://api.yarooms.com

# ── Redis (optional; bot falls back to in-memory cache when absent) ──────
# When running via docker compose the REDIS_URL is injected automatically
# as redis://redis:6379/0 — you don't need to set it here.
# REDIS_URL=redis://localhost:6379/0

# ── Logging (optional; default INFO) ─────────────────────────────────────
# LOG_LEVEL=DEBUG

